@{
    ViewData["Title"] = "Buscar Cliente";
}

<div class="container py-4">
    <div class="mb-4">
        <a href="/" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-search"></i> Localizar Cadastro</h4>
        </div>
        <div class="card-body p-4">
            <form action="/Home/BuscarCliente" method="get" class="row g-3 mb-4">
                <div class="col-md-8">
                    <input type="text" name="cpf" class="form-control form-control-lg" placeholder="Digite o CPF do cliente...">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary btn-lg w-100">Buscar</button>
                </div>
            </form>

            @if (ViewBag.Cliente != null)
            {
                <div class="alert alert-light border shadow-sm">
                    <h5 class="text-primary border-bottom pb-2">Resultado da Busca</h5>
                    <p><strong>Nome:</strong> @ViewBag.Cliente.Nome</p>
                    <p><strong>Veículo:</strong> @ViewBag.Cliente.Marca @ViewBag.Cliente.Modelo (@ViewBag.Cliente.Ano)</p>
                    <p><strong>Placa:</strong> <span class="badge bg-dark">@ViewBag.Cliente.Placa</span></p>
                    
                    <hr>
                    <a href="/Home/ConsultarOS" class="btn btn-warning btn-sm">Ver Histórico de O.S.</a>
                </div>
            }
            else if (ViewContext.HttpContext.Request.Query.ContainsKey("cpf"))
            {
                <div class="alert alert-danger">Cliente não encontrado com este CPF.</div>
            }
        </div>
    </div>
</div>