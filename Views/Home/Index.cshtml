@{
    ViewData["Title"] = "Início - Oficina";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-dark">OFICINA MECÂNICA</h1>
        <p class="lead text-secondary">Sistema de Gestão Integrado</p>
        <hr class="w-25 mx-auto">
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="card h-100 shadow-sm border-0 hover-shadow" style="cursor: pointer;" onclick="location.href='/Home/BuscarCliente'">
                <div class="card-body text-center p-5">
                    <div class="mb-3">
                        <i class="bi bi-search text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="card-title">Buscar Cliente</h3>
                    <p class="card-text text-muted">Localize cadastros existentes pelo CPF ou Nome.</p>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card h-100 shadow-sm border-0 hover-shadow" style="cursor: pointer;" onclick="location.href='/Home/CadastrarCliente'">
                <div class="card-body text-center p-5">
                    <div class="mb-3">
                        <i class="bi bi-person-plus text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="card-title">Cadastrar Cliente</h3>
                    <p class="card-text text-muted">Adicione novos clientes e veículos ao sistema.</p>
                </div>
            </div>
        </div>

        <div class="col-md-10">
            <div class="card shadow-sm border-0 hover-shadow" style="cursor: pointer;" onclick="location.href='/Home/BuscarOS'">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="me-4">
                        <i class="bi bi-file-earmark-text text-warning" style="font-size: 3rem;"></i>
                    </div>
                    <div>
                        <h3 class="card-title mb-1">Central de O.S.</h3>
                        <p class="card-text text-muted mb-0">Busque por Nome, CPF, Placa ou Modelo do carro.</p>
                    </div>
                    <div class="ms-auto">
                        <i class="bi bi-arrow-right-circle fs-2 text-secondary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        border: 1px solid #0d6efd !important;
    }
</style>